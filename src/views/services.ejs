<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/services.css">
</head>
<body>
    <!-- HEADER -->
    <header class="header">
        <div class="nav-container">
            <a href="/" class="logo">CryptoTrading</a>
            
            <!-- Botón hamburguesa -->
            <button class="mobile-menu-btn">
                <span class="hamburger-icon">☰</span>
            </button>

            <!-- Nav links -->
            <nav class="nav-links">
                <a href="/servicios">Servicios</a>
                <a href="#entrenamientos">Entrenamientos</a>
                <a href="#asesoramientos">Asesoramientos</a>
                <a href="#mentoring">Mentoring</a>
                <a href="#recursos">Recursos</a>
            </nav>
        </div>
    </header>

    <!-- VIDEO SECTION -->
    <% if (typeof video !== 'undefined' && video.id) { %>
        <section class="video-section">
            <div class="container">
                <h1 class="text-4xl font-bold mb-8 text-center"><%= title %></h1>
                <p class="text-xl mb-12 text-center text-gray-600"><%= description %></p>
                
                <div class="video-container">
                    <iframe 
                        width="100%" 
                        height="500"
                        src="https://www.youtube.com/embed/<%= video.id %>"
                        title="YouTube video player"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen>
                    </iframe>
                </div>
            </div>
        </section>
    <% } %>

    <!-- SERVICES SECTION -->
    <section class="services-section">
        <div class="services-container">
            <h2 class="section-title">Nuestros Servicios Premium</h2>
            
            <div class="services-grid">
                <!-- Señales Premium -->
                <div class="service-card">
                    <div class="card-header">
                        <h3>Señales Premium</h3>
                        <p>Señales de trading en tiempo real con alta precisión</p>
                    </div>                 
                    <ul class="feature-list">
                        <li>Señales 24/7 en tiempo real</li>
                        <li>Setup completo de entrada</li>
                        <li>Stop Loss y Take Profit</li>
                        <li>Análisis de mercado diario</li>
                    </ul>
                    
                    <button class="cta-button">
                        Comenzar Ahora
                    </button>
                </div>

                <!-- Mentoría PRO -->
                <div class="service-card">
                    <div class="card-header">
                        <h3>Mentoría PRO</h3>
                        <p>Formación personalizada con traders expertos</p>
                    </div>
                    
                    <ul class="feature-list">
                        <li>Sesiones personalizadas</li>
                        <li>Plan de trading individual</li>
                        <li>Revisión de operaciones</li>
                        <li>Soporte prioritario 24/7</li>
                    </ul>
                    
                    <button class="cta-button">
                        Reservar Mentoría
                    </button>
                </div>

                <!-- Comunidad VIP -->
                <div class="service-card">
                    <div class="card-header">
                        <h3>Comunidad VIP</h3>
                        <p>Acceso exclusivo a nuestra comunidad de traders</p>
                    </div>
                    
                    <ul class="feature-list">
                        <li>Chat grupal en tiempo real</li>
                        <li>Webinars semanales</li>
                        <li>Biblioteca de recursos</li>
                        <li>Eventos exclusivos</li>
                    </ul>
                    
                    <button class="cta-button">
                        Unirse Ahora
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- STATS SECTION -->
    <section class="stats-section">
        <div class="container">
            <div class="stats-container">
                <!-- Traders Activos -->
                <div class="stat-card">
                    <div class="stat-content">
                        <div class="stat-icon-wrapper">
                            <span class="stat-icon">👥</span>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number">1,500+</div>
                            <div class="stat-details">
                                <div class="stat-label">Traders Activos</div>
                                <div class="stat-description">en Señales Premium</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Alumnos -->
                <div class="stat-card">
                    <div class="stat-content">
                        <div class="stat-icon-wrapper">
                            <span class="stat-icon">👨‍🏫</span>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number">500+</div>
                            <div class="stat-details">
                                <div class="stat-label">Alumnos</div>
                                <div class="stat-description">en Mentoría PRO</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Miembros VIP -->
                <div class="stat-card">
                    <div class="stat-content">
                        <div class="stat-icon-wrapper">
                            <span class="stat-icon">🌟</span>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number">2,500+</div>
                            <div class="stat-details">
                                <div class="stat-label">Miembros VIP</div>
                                <div class="stat-description">en nuestra Comunidad</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="/js/navbar.js"></script>
</body>
</html> 