<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Servicios - CryptoTrading</title>
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/services.css">
    <link rel="stylesheet" href="/css/animations.css">
</head>
<body>
    
    <%- include('./partials/header') %>
    
    <!-- Video de Vimeo primero -->
    <div class="video-container">
        <iframe src="https://player.vimeo.com/video/[TU-ID-DE-VIDEO]" 
                frameborder="0" 
                allow="autoplay; fullscreen; picture-in-picture" 
                allowfullscreen>
        </iframe>
    </div>

    <!-- SERVICIOS SECTION -->
    <section class="services-section">
        <div class="container">
            <h2 class="section-title" data-animate="fade-up">Nuestros Servicios Premium</h2>
            
            <div class="services-grid">
                <!-- Señales Premium -->
                <div class="service-card" data-animate="fade-up" data-delay="100">
                    <div class="card-header">
                        <h3>Señales Premium</h3>
                        <p>Señales de trading en tiempo real con alta precisión</p>
                    </div>                 
                    <ul class="feature-list">
                        <li>Señales 24/7 en tiempo real</li>
                        <li>Setup completo de entrada</li>
                        <li>Stop Loss y Take Profit</li>
                        <li>Análisis de mercado diario</li>
                    </ul>
                    
                    <button class="cta-button" onclick="window.location.href='/servicios/senales-premium'">
                        Comenzar Ahora
                    </button>
                </div>

                <!-- Mentoría PRO -->
                <div class="service-card" data-animate="fade-up" data-delay="200">
                    <div class="card-header">
                        <h3>Mentoría PRO</h3>
                        <p>Formación personalizada con traders expertos</p>
                    </div>
                    
                    <ul class="feature-list">
                        <li>Sesiones personalizadas</li>
                        <li>Plan de trading individual</li>
                        <li>Revisión de operaciones</li>
                        <li>Soporte prioritario 24/7</li>
                    </ul>
                    
                    <button class="cta-button" onclick="window.location.href='/servicios/mentoria-pro'">
                        Reservar Mentoría
                    </button>
                </div>

                <!-- Comunidad VIP -->
                <div class="service-card" data-animate="fade-up" data-delay="300">
                    <div class="card-header">
                        <h3>Comunidad VIP</h3>
                        <p>Acceso exclusivo a nuestra comunidad de traders</p>
                    </div>
                    
                    <ul class="feature-list">
                        <li>Chat grupal en tiempo real</li>
                        <li>Webinars semanales</li>
                        <li>Biblioteca de recursos</li>
                        <li>Eventos exclusivos</li>
                    </ul>
                    
                    <button class="cta-button" onclick="window.location.href='/servicios/comunidad-vip'">
                        Unirse Ahora
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Espaciador -->
    <div class="py-20"></div>

    <!-- STATS SECTION -->
    <section class="stats-section">
        <div class="container">
            <div class="stats-container">
                <!-- Traders Activos -->
                <div class="stat-card">
                    <div class="stat-content">
                        <div class="stat-icon-wrapper">
                            <span class="stat-icon">👥</span>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number">1,500+</div>
                            <div class="stat-details">
                                <div class="stat-label">Traders Activos</div>
                                <div class="stat-description">en Señales Premium</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Alumnos -->
                <div class="stat-card">
                    <div class="stat-content">
                        <div class="stat-icon-wrapper">
                            <span class="stat-icon">👨‍🏫</span>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number">500+</div>
                            <div class="stat-details">
                                <div class="stat-label">Alumnos</div>
                                <div class="stat-description">en Mentoría PRO</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Miembros VIP -->
                <div class="stat-card">
                    <div class="stat-content">
                        <div class="stat-icon-wrapper">
                            <span class="stat-icon">🌟</span>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number">2,500+</div>
                            <div class="stat-details">
                                <div class="stat-label">Miembros VIP</div>
                                <div class="stat-description">en nuestra Comunidad</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="/js/navbar.js"></script>
</body>
</html> 