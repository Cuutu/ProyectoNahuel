<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/popup.css">
</head>
<body>
    <!-- HEADER -->
    <header class="header">
        <div class="nav-container">
            <a href="/" class="logo">CryptoTrading</a>
            
            <!-- Botón hamburguesa -->
            <button class="mobile-menu-btn">
                <span class="hamburger-icon">☰</span>
            </button>

            <!-- Nav links -->
            <nav class="nav-links">
                <a href="/servicios">Servicios</a>
                <a href="#entrenamientos">Entrenamientos</a>
                <a href="#asesoramientos">Asesoramientos</a>
                <a href="#mentoring">Mentoring</a>
                <a href="#recursos">Recursos</a>
            </nav>
        </div>
    </header>

    <!-- SERVICES SECTION -->
    <section class="hero-section">
        <div class="container">
            <div class="content-grid">
                <!-- Señales Premium -->
                <div class="feature-card">
                    <div class="card-content">
                        <h3>Señales Premium</h3>
                        <p>Señales de trading en tiempo real con alta precisión</p>
                        
                        <div class="stats-container">
                            <div class="stat">
                                <span class="stat-number">1500+</span>
                                <span class="stat-text">Traders</span>
                            </div>
                            <div class="stat">
                                <span class="stat-number">89%</span>
                                <span class="stat-text">Precisión</span>
                            </div>
                        </div>
                        
                        <ul class="benefits-list">
                            <li>Señales 24/7 en tiempo real</li>
                            <li>Setup completo de entrada</li>
                            <li>Stop Loss y Take Profit</li>
                            <li>Análisis de mercado diario</li>
                        </ul>
                        
                        <button class="cta-button">
                            Comenzar Ahora
                        </button>
                    </div>
                </div>

                <!-- Mentoría PRO -->
                <div class="feature-card">
                    <div class="card-content">
                        <h3>Mentoría PRO</h3>
                        <p>Formación personalizada con traders expertos</p>
                        
                        <div class="stats-container">
                            <div class="stat">
                                <span class="stat-number">500+</span>
                                <span class="stat-text">Alumnos</span>
                            </div>
                            <div class="stat">
                                <span class="stat-number">12</span>
                                <span class="stat-text">Sesiones</span>
                            </div>
                        </div>
                        
                        <ul class="benefits-list">
                            <li>Sesiones personalizadas</li>
                            <li>Plan de trading individual</li>
                            <li>Revisión de operaciones</li>
                            <li>Soporte prioritario 24/7</li>
                        </ul>
                        
                        <button class="cta-button">
                            Reservar Mentoría
                        </button>
                    </div>
                </div>

                <!-- Comunidad VIP -->
                <div class="feature-card">
                    <div class="card-content">
                        <h3>Comunidad VIP</h3>
                        <p>Acceso exclusivo a nuestra comunidad de traders</p>
                        
                        <div class="stats-container">
                            <div class="stat">
                                <span class="stat-number">2500+</span>
                                <span class="stat-text">Miembros</span>
                            </div>
                            <div class="stat">
                                <span class="stat-number">24/7</span>
                                <span class="stat-text">Soporte</span>
                            </div>
                        </div>
                        
                        <ul class="benefits-list">
                            <li>Chat grupal en tiempo real</li>
                            <li>Webinars semanales</li>
                            <li>Biblioteca de recursos</li>
                            <li>Eventos exclusivos</li>
                        </ul>
                        
                        <button class="cta-button">
                            Unirse Ahora
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="/js/navbar.js"></script>
</body>
</html> 