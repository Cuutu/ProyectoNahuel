<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/services.css">
</head>
<body>
    <!-- HEADER -->
    <header class="header">
        <div class="nav-container">
            <a href="/" class="logo">CryptoTrading</a>
            
            <!-- Botón hamburguesa -->
            <button class="mobile-menu-btn">
                <span class="hamburger-icon">☰</span>
            </button>

            <!-- Nav links -->
            <nav class="nav-links">
                <a href="/servicios">Servicios</a>
                <a href="#entrenamientos">Entrenamientos</a>
                <a href="#asesoramientos">Asesoramientos</a>
                <a href="#mentoring">Mentoring</a>
                <a href="#recursos">Recursos</a>
            </nav>
        </div>
    </header>

    <!-- VIDEO SECTION -->
    <section class="video-section bg-gray-100 py-16">
        <div class="container">
            <h1 class="text-4xl font-bold mb-8"><%= title %></h1>
            <p class="text-xl mb-12"><%= description %></p>
            
            <div class="video-wrapper aspect-w-16 aspect-h-9">
                <iframe 
                    src="https://www.youtube.com/embed/<%= video.id %>" 
                    frameborder="0" 
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                    allowfullscreen>
                </iframe>
            </div>
        </div>
    </section>

    <!-- SERVICES SECTION -->
    <section class="services-section py-16">
        <div class="container">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <% services.forEach(service => { %>
                    <div class="service-card">
                        <div class="card-header">
                            <h3 class="text-2xl font-bold"><%= service.title %></h3>
                            <p class="text-gray-600"><%= service.description %></p>
                        </div>
                        
                        <div class="card-stats">
                            <div class="stat">
                                <span class="stat-value"><%= service.subscribers %></span>
                                <span class="stat-label">Suscriptores</span>
                            </div>
                            <div class="stat">
                                <span class="stat-value"><%= service.userType %></span>
                                <span class="stat-label">Perfil Ideal</span>
                            </div>
                        </div>
                        
                        <ul class="feature-list">
                            <% service.features.forEach(feature => { %>
                                <li><%= feature %></li>
                            <% }) %>
                        </ul>
                        
                        <button class="cta-button w-full">
                            Comenzar Ahora
                        </button>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>

    <script src="/js/navbar.js"></script>
</body>
</html> 