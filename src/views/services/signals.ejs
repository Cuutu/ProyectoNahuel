<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Señales Premium - CryptoTrading</title>
    <!-- Agregar Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico">
</head>
<body>
<%- include('../partials/header') %>

<div class="service-container">
    <% if (hasActiveSubscription) { %>
        <!-- Contenido para usuarios con suscripción activa -->
        <div class="signals-content">
            <h2>Señales Premium Activas</h2>
            <!-- Aquí va el contenido exclusivo -->
            <div class="signals-dashboard">
                <!-- Contenido de las señales -->
            </div>
        </div>
    <% } else { %>
        <!-- Template de venta normal -->
        <%- include('../services/service-template', {
            service: {
                name: "Señales Premium",
                description: "Señales de trading en tiempo real con alta precisión",
                price: "99.99",
                features: [
                    "Señales 24/7 en tiempo real",
                    "Setup completo de entrada",
                    "Stop Loss y Take Profit",
                    "Análisis de mercado diario"
                ]
            }
        }); %>
    <% } %>
</div>

<%- include('../partials/footer') %>

<!-- Agregar el SDK de MercadoPago -->
<script src="https://sdk.mercadopago.com/js/v2"></script>

<!-- Script de inicialización -->
<script>
// Definir la función antes de usarla
async function initPayment() {
    try {
        const response = await fetch('/payment/create-order', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        
        if (data.id) {
            const mp = new MercadoPago('<%= process.env.MERCADOPAGO_PUBLIC_KEY %>');
            const checkout = mp.checkout({
                preference: {
                    id: data.id
                },
                render: {
                    container: '.cho-container',
                    label: 'Contratar Ahora'
                },
                theme: {
                    elementsColor: '#00E676',
                    headerColor: '#00E676'
                }
            });
        } else {
            console.error('No se recibió ID de preferencia:', data);
        }
    } catch (error) {
        console.error('Error en initPayment:', error);
    }
}

// Asegurarnos de que el script de MercadoPago esté cargado
document.addEventListener('DOMContentLoaded', function() {
    if (typeof MercadoPago === 'undefined') {
        console.error('MercadoPago script no está cargado');
    }
});
</script>
</body>
</html> 