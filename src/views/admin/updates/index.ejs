<%- include('../../../partials/header') %>

<div class="container">
    <div class="admin-header">
        <h1>Gestión de Actualizaciones</h1>
        <a href="/admin/updates/new" class="admin-btn">
            Nueva Actualización
        </a>
    </div>

    <div class="updates-list">
        <% if (updates && updates.length > 0) { %>
            <% updates.forEach(update => { %>
                <div class="update-card">
                    <h2><%= update.title %></h2>
                    <p class="update-date"><%= new Date(update.createdAt).toLocaleDateString() %></p>
                    <p class="update-content"><%= update.content %></p>
                    <div class="update-actions">
                        <a href="/admin/updates/edit/<%= update._id %>" class="btn-edit">Editar</a>
                        <button class="btn-delete" data-id="<%= update._id %>">Eliminar</button>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p class="no-updates">No hay actualizaciones disponibles</p>
        <% } %>
    </div>
</div>