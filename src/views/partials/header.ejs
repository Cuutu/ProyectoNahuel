<header class="header">
    <div class="nav-container">
        <a href="/" class="logo">CryptoTrading</a>
        
        <button class="mobile-menu-btn">
            <span class="hamburger-icon">☰</span>
        </button>

        <nav class="nav-links">
            <a href="/servicios">Servicios</a>
            <a href="/entrenamientos">Entrenamientos</a>
            <a href="/asesoramientos">Asesoramientos</a>
            <a href="/mentoring">Mentoring</a>
            <a href="/recursos">Recursos</a>
            
            <% if (locals.user && locals.user.id) { %>
                <div class="user-menu">
                    <span class="user-name">Hola, <%= locals.user.nombre %></span>
                    <a href="/user/dashboard" class="nav-link">Mi Perfil</a>
                    <form action="/auth/logout" method="POST" class="logout-form">
                        <button type="submit" class="logout-btn">Cerrar Sesión</button>
                    </form>
                </div>
            <% } else { %>
                <div class="auth-buttons">
                    <a href="/auth/login" class="auth-btn login">Iniciar Sesión</a>
                    <a href="/auth/register" class="auth-btn register">Registrarse</a>
                </div>
            <% } %>
        </nav>
    </div>
</header> 