<%- include('../partials/header') %>

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-800 mb-8">Recursos de Trading</h1>
    
    <div class="space-y-12">
        <% resources.forEach(category => { %>
            <div class="category-section">
                <h2 class="text-2xl font-semibold text-gray-700 mb-6"><%= category.category %></h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% category.items.forEach(item => { %>
                        <div class="bg-white rounded-lg shadow-md overflow-hidden">
                            <div class="relative">
                                <img 
                                    src="<%= item.imageUrl %>" 
                                    alt="<%= item.title %>"
                                    class="w-full h-48 object-cover"
                                >
                                <% if (item.isPremium) { %>
                                    <span class="absolute top-2 right-2 bg-yellow-400 text-black px-3 py-1 rounded-full text-sm font-semibold">
                                        Premium
                                    </span>
                                <% } %>
                            </div>
                            
                            <div class="p-6">
                                <h3 class="text-xl font-semibold text-gray-800 mb-2">
                                    <%= item.title %>
                                </h3>
                                <p class="text-gray-600 mb-4">
                                    <%= item.description %>
                                </p>
                                
                                <% if (item.isPremium && !isAuthenticated) { %>
                                    <a href="/auth/login" class="block text-center bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition">
                                        Acceder como Premium
                                    </a>
                                <% } else { %>
                                    <a href="<%= item.downloadUrl %>" class="block text-center bg-green-600 text-white px-4 py-2 rounded-md hover:bg-green-700 transition">
                                        Descargar
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include('../partials/footer') %> 