<%- include('../partials/header') %>

<link rel="stylesheet" href="/css/resources.css">

<div class="resources-container">
    <h1 class="resources-title">Recursos de Trading</h1>
    
    <div class="resources-grid">
        <% resources.forEach(category => { %>
            <div class="category-section">
                <h2 class="text-2xl font-semibold text-gray-700 mb-6"><%= category.category %></h2>
                
                <div class="resources-grid">
                    <% category.items.forEach(item => { %>
                        <div class="resource-card">
                            <img 
                                src="<%= item.imageUrl %>" 
                                alt="<%= item.title %>"
                                class="w-full h-48 object-cover rounded-t-lg"
                            >
                            <% if (item.isPremium) { %>
                                <span class="premium-badge">Premium</span>
                            <% } %>
                            
                            <div class="p-6">
                                <h3 class="text-xl font-semibold text-gray-800 mb-2">
                                    <%= item.title %>
                                </h3>
                                <p class="text-gray-600 mb-4">
                                    <%= item.description %>
                                </p>
                                
                                <% if (item.isPremium && !isAuthenticated) { %>
                                    <a href="/auth/login" class="resource-button">
                                        Acceder como Premium
                                    </a>
                                <% } else { %>
                                    <a href="<%= item.downloadUrl %>" class="resource-button">
                                        Descargar
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include('../partials/footer') %> 