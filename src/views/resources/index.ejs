<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recursos - CryptoTrading</title>
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="stylesheet" href="/css/resources.css">
</head>
<body>
    <%- include('../partials/header') %>
    
    <main class="resources-container">
        <section class="hero-section" data-animate="fade-up">
            <h1>Recursos de Trading</h1>
            <p>Herramientas y materiales para tu éxito</p>
        </section>

        <div class="resources-grid">
            <% resources.forEach(category => { %>
                <div class="category-section">
                    <h2><%= category.category %></h2>
                    
                    <div class="resources-grid">
                        <% category.items.forEach(item => { %>
                            <div class="resource-card">
                                <img src="<%= item.imageUrl %>" alt="<%= item.title %>">
                                <% if (item.isPremium) { %>
                                    <span class="premium-badge">Premium</span>
                                <% } %>
                                
                                <div class="card-content">
                                    <h3><%= item.title %></h3>
                                    <p><%- item.description %></p>
                                    
                                    <% if (item.isPremium && !isAuthenticated) { %>
                                        <a href="/auth/login" class="resource-button">
                                            Acceder como Premium
                                        </a>
                                    <% } else { %>
                                        <a href="<%= item.downloadUrl %>" 
                                           class="resource-button"
                                           target="_blank" 
                                           rel="noopener noreferrer">
                                            <%= item.buttonText || 'Descargar' %>
                                        </a>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>

    <script src="/js/animations.js"></script>
    <script src="/js/navbar.js"></script>

    <!-- Modal para la fórmula -->
    <div id="formulaModal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2>Fórmula de Dólar CCL</h2>
            <div class="formula-container">
                <code id="formula">(BCBA:KO*5/NYSE:KO+BCBA:AAPL*20/NASDAQ:AAPL+BCBA:MSFT*30/NASDAQ:MSFT+BCBA:GOLD*2/NYSE:GOLD)/4</code>
                <button id="copyButton" class="copy-button">Copiar</button>
            </div>
        </div>
    </div>

    <!-- Modal para la fórmula de Acciones ARG en CCL -->
    <div id="formulaModalArg" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2>Fórmula de Acciones ARG en CCL</h2>
            <div class="formula-container">
                <code id="formulaArg">BCBA:ALUA/((BCBA:KO*5/NYSE:KO+BCBA:AAPL*20/NASDAQ:AAPL+BCBA:MSFT*30/NASDAQ:MSFT+BCBA:GOLD*2/NYSE:GOLD)/4)</code>
                <button id="copyButtonArg" class="copy-button">Copiar</button>
            </div>
        </div>
    </div>

    <!-- Modal para la fórmula del MERVAL en CCL -->
    <div id="formulaModalMerval" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2>Fórmula MERVAL en Dólar CCL</h2>
            <div class="formula-container">
                <code id="formulaMerval">BCBA:IMV/((BCBA:KO*5/NYSE:KO+BCBA:AAPL*20/NASDAQ:AAPL+BCBA:MSFT*30/NASDAQ:MSFT+BCBA:GOLD*2/NYSE:GOLD)/4)</code>
                <button id="copyButtonMerval" class="copy-button">Copiar</button>
            </div>
        </div>
    </div>

    <!-- Agregar estos estilos -->
    <style>
    .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
    }

    .modal-content {
        background-color: #fefefe;
        margin: 15% auto;
        padding: 20px;
        border: 1px solid #888;
        width: 80%;
        max-width: 600px;
        border-radius: 8px;
        position: relative;
    }

    .close {
        position: absolute;
        right: 20px;
        top: 10px;
        color: #aaa;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
    }

    .formula-container {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 6px;
        margin: 20px 0;
        position: relative;
        overflow-x: auto;
    }

    .copy-button {
        background: #00ff88;
        color: black;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        cursor: pointer;
        margin-top: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .copy-button:hover {
        background: #00cc6a;
        transform: translateY(-2px);
    }
    </style>

    <!-- Agregar este script -->
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const modal = document.getElementById('formulaModal');
        const modalArg = document.getElementById('formulaModalArg');
        const modalMerval = document.getElementById('formulaModalMerval');
        const formula = document.getElementById('formula');
        const formulaArg = document.getElementById('formulaArg');
        const formulaMerval = document.getElementById('formulaMerval');
        const copyButton = document.getElementById('copyButton');
        const copyButtonArg = document.getElementById('copyButtonArg');
        const copyButtonMerval = document.getElementById('copyButtonMerval');
        const closeBtns = document.getElementsByClassName('close');

        // Abrir modal correspondiente según el botón
        document.querySelectorAll('.resource-button').forEach(button => {
            button.onclick = function(e) {
                if (button.closest('.resource-card').querySelector('h3').textContent.includes('Dolar CCL')) {
                    e.preventDefault();
                    modal.style.display = 'block';
                } else if (button.closest('.resource-card').querySelector('h3').textContent.includes('Acciones ARG')) {
                    e.preventDefault();
                    modalArg.style.display = 'block';
                } else if (button.closest('.resource-card').querySelector('h3').textContent.includes('MERVAL')) {
                    e.preventDefault();
                    modalMerval.style.display = 'block';
                }
            }
        });

        // Cerrar modales
        Array.from(closeBtns).forEach(btn => {
            btn.onclick = function() {
                modal.style.display = 'none';
                modalArg.style.display = 'none';
                modalMerval.style.display = 'none';
            }
        });

        window.onclick = function(event) {
            if (event.target == modal || event.target == modalArg || event.target == modalMerval) {
                modal.style.display = 'none';
                modalArg.style.display = 'none';
                modalMerval.style.display = 'none';
            }
        }

        // Copiar fórmulas
        function setupCopyButton(button, formula) {
            button.onclick = function() {
                navigator.clipboard.writeText(formula.textContent).then(() => {
                    button.textContent = '¡Copiado!';
                    setTimeout(() => {
                        button.textContent = 'Copiar';
                    }, 2000);
                });
            }
        }

        setupCopyButton(copyButton, formula);
        setupCopyButton(copyButtonArg, formulaArg);
        setupCopyButton(copyButtonMerval, formulaMerval);
    });
    </script>
</body>
</html> 