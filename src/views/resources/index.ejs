    <!-- Agregar estos estilos -->
    <style>
    .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
        transition: opacity 0.3s ease;
    }

    .modal.show {
        display: block;
    }

    .modal-content {
        background-color: #fefefe;
        margin: 5% auto;
        padding: 20px;
        border: 1px solid #888;
        width: 90%;
        max-width: 800px;
        max-height: 90vh;
        overflow-y: auto;
        border-radius: 8px;
        position: relative;
        transform: translateY(0);
        transition: transform 0.3s ease;
    }

    .close {
        position: absolute;
        right: 20px;
        top: 10px;
        color: #aaa;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
    }

    .formula-container {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 6px;
        margin: 20px 0;
        position: relative;
        overflow-x: auto;
    }

    .copy-button {
        background: #00ff88;
        color: black;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        cursor: pointer;
        margin-top: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .copy-button:hover {
        background: #00cc6a;
        transform: translateY(-2px);
    }

    .formula-section {
        margin-bottom: 2rem;
    }

    .formula-section h3 {
        color: #333;
        margin-bottom: 1rem;
        font-size: 1.2rem;
    }

    .formula-container {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 6px;
        margin: 10px 0;
        position: relative;
        overflow-x: auto;
    }

    /* Modal de Calendarios */
    .calendar-modal {
        background: #ffffff;
        border-radius: 15px;
        padding: 2rem;
        max-width: 600px;
    }

    .calendar-title {
        color: #333;
        font-size: 1.8rem;
        font-weight: 600;
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #00ff88;
    }

    .calendar-links {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .calendar-button {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        background: #f8f9fa;
        color: #333;
        padding: 1.2rem;
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 1px solid #eee;
    }

    .calendar-button:hover {
        background: #fff;
        transform: translateY(-3px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.1);
        border-color: #00ff88;
    }

    .calendar-button i {
        font-size: 1.5rem;
        color: #00ff88;
        width: 40px;
        text-align: center;
    }

    .calendar-button-content {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .calendar-button-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
    }

    .calendar-button-desc {
        font-size: 0.9rem;
        color: #666;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .calendar-modal {
            margin: 1rem;
            padding: 1.5rem;
        }

        .calendar-button {
            padding: 1rem;
        }

        .calendar-button-title {
            font-size: 1rem;
        }

        .calendar-button-desc {
            font-size: 0.8rem;
        }
    }

    .resources-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
    }

    .section-block {
        margin-bottom: 4rem;
    }

    .section-title {
        text-align: center;
        font-size: 2rem;
        color: #333;
        margin-bottom: 2rem;
        position: relative;
    }

    .section-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 200px;
        height: 3px;
        background: #00ff88;
    }

    .carousel-box {
        border: 2px solid #eee;
        border-radius: 10px;
        padding: 2rem;
        background: #fff;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .carousel-container {
        position: relative;
        width: 100%;
        overflow: hidden;
        padding: 0 40px;
    }

    .carousel-track {
        display: flex;
        transition: transform 0.5s ease;
    }

    .carousel-button {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: #00ff88;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        z-index: 10;
        font-size: 20px;
        color: black;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .carousel-button:hover {
        background: #00cc6a;
        transform: translateY(-50%) scale(1.1);
    }

    .carousel-button.prev {
        left: 0;
    }

    .carousel-button.next {
        right: 0;
    }

    .resource-card {
        flex: 0 0 100%;
        max-width: 500px;
        margin: 0 auto;
    }

    @media (max-width: 768px) {
        .carousel-container {
            padding: 0 30px;
        }
        
        .resource-card {
            flex: 0 0 260px;
        }
        
        .section-title {
            font-size: 1.5rem;
        }
        
        .section-title::after {
            width: 150px;
        }
    }
    </style>

    <!-- Agregar este script -->
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const formulaModal = document.getElementById('formulaModal');
        const calendarModal = document.getElementById('calendarModal');
        const closeBtns = document.getElementsByClassName('close');

        // Capturar clicks en botones
        document.querySelectorAll('.resource-button').forEach(button => {
            button.addEventListener('click', function(e) {
                const buttonText = this.textContent.trim();
                
                if (buttonText === 'Ver calendarios') {
                    e.preventDefault();
                    calendarModal.style.display = 'block';
                } else if (buttonText === 'Ver indices' || buttonText === 'Ver formula') {
                    e.preventDefault();
                    formulaModal.style.display = 'block';
                }
            });
        });

        // Cerrar modales
        Array.from(closeBtns).forEach(btn => {
            btn.onclick = function() {
                formulaModal.style.display = 'none';
                calendarModal.style.display = 'none';
            }
        });

        window.onclick = function(event) {
            if (event.target == formulaModal || event.target == calendarModal) {
                formulaModal.style.display = 'none';
                calendarModal.style.display = 'none';
            }
        }

        // Copiar fórmulas
        document.querySelectorAll('.copy-button').forEach(button => {
            button.onclick = function() {
                const formula = this.previousElementSibling;
                navigator.clipboard.writeText(formula.textContent).then(() => {
                    button.textContent = '¡Copiado!';
                    setTimeout(() => {
                        button.textContent = 'Copiar';
                    }, 2000);
                });
            }
        });

        const tracks = document.querySelectorAll('.carousel-track');
        
        tracks.forEach(track => {
            const cards = track.children;
            let currentIndex = 0;
            
            // Función para mover al siguiente slide
            function nextSlide() {
                currentIndex = (currentIndex + 1) % cards.length;
                track.style.transform = `translateX(-${currentIndex * 100}%)`;
            }

            // Función para mover al slide anterior
            function prevSlide() {
                currentIndex = (currentIndex - 1 + cards.length) % cards.length;
                track.style.transform = `translateX(-${currentIndex * 100}%)`;
            }

            // Configurar botones de navegación
            const prevButton = track.parentElement.querySelector('.prev');
            const nextButton = track.parentElement.querySelector('.next');
            
            prevButton.addEventListener('click', () => {
                clearInterval(autoSlide); // Detener el deslizamiento automático al hacer clic
                prevSlide();
                startAutoSlide(); // Reiniciar el deslizamiento automático
            });
            
            nextButton.addEventListener('click', () => {
                clearInterval(autoSlide); // Detener el deslizamiento automático al hacer clic
                nextSlide();
                startAutoSlide(); // Reiniciar el deslizamiento automático
            });

            // Deslizamiento automático
            let autoSlide;
            
            function startAutoSlide() {
                autoSlide = setInterval(nextSlide, 2000); // Cambiar cada 2 segundos
            }

            // Pausar el deslizamiento automático cuando el mouse está sobre el carrusel
            track.parentElement.addEventListener('mouseenter', () => {
                clearInterval(autoSlide);
            });

            // Reanudar el deslizamiento automático cuando el mouse sale del carrusel
            track.parentElement.addEventListener('mouseleave', () => {
                startAutoSlide();
            });

            // Iniciar el deslizamiento automático
            startAutoSlide();
        });
    });
    </script>
</body>
</html> 