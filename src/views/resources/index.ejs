<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recursos - CryptoTrading</title>
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="stylesheet" href="/css/resources.css">
</head>
<body>
    <%- include('../partials/header') %>
    
    <main class="resources-container">
        <section class="hero-section" data-animate="fade-up">
            <h1>Recursos de Trading</h1>
            <p>Herramientas y materiales para tu éxito</p>
        </section>

        <div class="resources-grid">
            <% resources.forEach(category => { %>
                <div class="category-section">
                    <h2><%= category.category %></h2>
                    
                    <div class="resources-grid">
                        <% category.items.forEach(item => { %>
                            <div class="resource-card">
                                <img src="<%= item.imageUrl %>" alt="<%= item.title %>">
                                <% if (item.isPremium) { %>
                                    <span class="premium-badge">Premium</span>
                                <% } %>
                                
                                <div class="card-content">
                                    <h3><%= item.title %></h3>
                                    <p><%- item.description %></p>
                                    
                                    <% if (item.isPremium && !isAuthenticated) { %>
                                        <a href="/auth/login" class="resource-button">
                                            Acceder como Premium
                                        </a>
                                    <% } else { %>
                                        <a href="<%= item.downloadUrl %>" 
                                           class="resource-button"
                                           target="_blank" 
                                           rel="noopener noreferrer">
                                            <%= item.buttonText || 'Descargar' %>
                                        </a>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>

    <script src="/js/animations.js"></script>
    <script src="/js/navbar.js"></script>

    <!-- Un solo modal para todas las fórmulas -->
    <div id="formulaModal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2>Índices más utilizados</h2>
            
            <div class="formula-section">
                <h3>Dólar CCL</h3>
                <div class="formula-container">
                    <code id="formula">(BCBA:KO*5/NYSE:KO+BCBA:AAPL*20/NASDAQ:AAPL+BCBA:MSFT*30/NASDAQ:MSFT+BCBA:GOLD*2/NYSE:GOLD)/4</code>
                    <button class="copy-button">Copiar</button>
                </div>
            </div>

            <div class="formula-section">
                <h3>Acciones ARG en CCL</h3>
                <div class="formula-container">
                    <code id="formulaArg">BCBA:ALUA/((BCBA:KO*5/NYSE:KO+BCBA:AAPL*20/NASDAQ:AAPL+BCBA:MSFT*30/NASDAQ:MSFT+BCBA:GOLD*2/NYSE:GOLD)/4)</code>
                    <button class="copy-button">Copiar</button>
                </div>
            </div>

            <div class="formula-section">
                <h3>MERVAL en Dólar CCL</h3>
                <div class="formula-container">
                    <code id="formulaMerval">BCBA:IMV/((BCBA:KO*5/NYSE:KO+BCBA:AAPL*20/NASDAQ:AAPL+BCBA:MSFT*30/NASDAQ:MSFT+BCBA:GOLD*2/NYSE:GOLD)/4)</code>
                    <button class="copy-button">Copiar</button>
                </div>
            </div>
            <div class="formula-section">
                <h3>Comparación S&P500 y MERVAL</h3>
                <div class="formula-container">
                    <code id="formulaMerval">AMEX:SPY/(BCBA:IMV/((BCBA:KO*5/NYSE:KO+BCBA:AAPL*20/NASDAQ:AAPL+BCBA:MSFT*30/NASDAQ:MSFT+BCBA:GOLD*2/NYSE:GOLD)/4))</code>
                    <button class="copy-button">Copiar</button>
                </div>
            </div>
            <div class="formula-section">
                <h3>Comparación NASDAQ 100 y DOW JONES 30</h3>
                <div class="formula-container">
                    <code id="formulaMerval">NASDAQ:NDX/TVC:DJI</code>
                    <button class="copy-button">Copiar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal para calendarios -->
    <div id="calendarModal" class="modal">
        <div class="modal-content calendar-modal">
            <span class="close">&times;</span>
            <h2 class="calendar-title">Calendarios Económicos</h2>
            
            <div class="calendar-links">
                <a href="https://es.investing.com/economic-calendar/cpi-733" 
                   class="calendar-button"
                   target="_blank"
                   rel="noopener noreferrer">
                    <i class="fas fa-chart-line"></i>
                    <div class="calendar-button-content">
                        <span class="calendar-button-title">Inflación USA (CPI)</span>
                        <span class="calendar-button-desc">Datos mensuales de inflación estadounidense</span>
                    </div>
                </a>
                
                <a href="https://es.investing.com/economic-calendar/interest-rate-decision-168" 
                   class="calendar-button"
                   target="_blank"
                   rel="noopener noreferrer">
                    <i class="fas fa-university"></i>
                    <div class="calendar-button-content">
                        <span class="calendar-button-title">FED (Tasa de Interés)</span>
                        <span class="calendar-button-desc">Decisiones de la Reserva Federal sobre tasas</span>
                    </div>
                </a>
                
                <a href="https://es.investing.com/earnings-calendar/" 
                   class="calendar-button"
                   target="_blank"
                   rel="noopener noreferrer">
                    <i class="fas fa-file-invoice-dollar"></i>
                    <div class="calendar-button-content">
                        <span class="calendar-button-title">Calendario de Balances</span>
                        <span class="calendar-button-desc">Reportes financieros de empresas</span>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Agregar estos estilos -->
    <style>
    .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
        transition: opacity 0.3s ease;
    }

    .modal.show {
        display: block;
    }

    .modal-content {
        background-color: #fefefe;
        margin: 5% auto;
        padding: 20px;
        border: 1px solid #888;
        width: 90%;
        max-width: 800px;
        max-height: 90vh;
        overflow-y: auto;
        border-radius: 8px;
        position: relative;
        transform: translateY(0);
        transition: transform 0.3s ease;
    }

    .close {
        position: absolute;
        right: 20px;
        top: 10px;
        color: #aaa;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
    }

    .formula-container {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 6px;
        margin: 20px 0;
        position: relative;
        overflow-x: auto;
    }

    .copy-button {
        background: #00ff88;
        color: black;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        cursor: pointer;
        margin-top: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .copy-button:hover {
        background: #00cc6a;
        transform: translateY(-2px);
    }

    .formula-section {
        margin-bottom: 2rem;
    }

    .formula-section h3 {
        color: #333;
        margin-bottom: 1rem;
        font-size: 1.2rem;
    }

    .formula-container {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 6px;
        margin: 10px 0;
        position: relative;
        overflow-x: auto;
    }

    /* Modal de Calendarios */
    .calendar-modal {
        background: #ffffff;
        border-radius: 15px;
        padding: 2rem;
        max-width: 600px;
    }

    .calendar-title {
        color: #333;
        font-size: 1.8rem;
        font-weight: 600;
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #00ff88;
    }

    .calendar-links {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .calendar-button {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        background: #f8f9fa;
        color: #333;
        padding: 1.2rem;
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 1px solid #eee;
    }

    .calendar-button:hover {
        background: #fff;
        transform: translateY(-3px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.1);
        border-color: #00ff88;
    }

    .calendar-button i {
        font-size: 1.5rem;
        color: #00ff88;
        width: 40px;
        text-align: center;
    }

    .calendar-button-content {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .calendar-button-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
    }

    .calendar-button-desc {
        font-size: 0.9rem;
        color: #666;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .calendar-modal {
            margin: 1rem;
            padding: 1.5rem;
        }

        .calendar-button {
            padding: 1rem;
        }

        .calendar-button-title {
            font-size: 1rem;
        }

        .calendar-button-desc {
            font-size: 0.8rem;
        }
    }
    </style>

    <!-- Agregar este script -->
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const formulaModal = document.getElementById('formulaModal');
        const calendarModal = document.getElementById('calendarModal');
        const closeBtns = document.getElementsByClassName('close');

        // Capturar clicks en botones
        document.querySelectorAll('.resource-button').forEach(button => {
            button.addEventListener('click', function(e) {
                const buttonText = this.textContent.trim();
                
                if (buttonText === 'Ver calendarios') {
                    e.preventDefault();
                    calendarModal.style.display = 'block';
                } else if (buttonText === 'Ver indices' || buttonText === 'Ver formula') {
                    e.preventDefault();
                    formulaModal.style.display = 'block';
                }
            });
        });

        // Cerrar modales
        Array.from(closeBtns).forEach(btn => {
            btn.onclick = function() {
                formulaModal.style.display = 'none';
                calendarModal.style.display = 'none';
            }
        });

        window.onclick = function(event) {
            if (event.target == formulaModal || event.target == calendarModal) {
                formulaModal.style.display = 'none';
                calendarModal.style.display = 'none';
            }
        }

        // Copiar fórmulas
        document.querySelectorAll('.copy-button').forEach(button => {
            button.onclick = function() {
                const formula = this.previousElementSibling;
                navigator.clipboard.writeText(formula.textContent).then(() => {
                    button.textContent = '¡Copiado!';
                    setTimeout(() => {
                        button.textContent = 'Copiar';
                    }, 2000);
                });
            }
        });
    });
    </script>
</body>
</html> 