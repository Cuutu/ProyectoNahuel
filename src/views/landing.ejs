<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
</head>
<body class="font-sans">
    <!-- HEADER -->
    <header class="fixed w-full bg-white/95 backdrop-blur-sm border-b border-gray-200 z-50">
        <div class="container flex items-center justify-between py-4">
            <a href="/" class="text-xl font-bold tracking-tight">CryptoTrading</a>
            <nav class="hidden md:flex items-center space-x-8">
                <a href="#video" class="text-sm font-medium hover:text-gray-600">Video</a>
                <a href="#info" class="text-sm font-medium hover:text-gray-600">Características</a>
                <a href="#contacto" class="text-sm font-medium hover:text-gray-600">Contacto</a>
            </nav>
        </div>
    </header>

    <!-- VIDEO SECTION -->
    <section id="video" class="pt-24 pb-12">
        <div class="container">
            <div class="video-wrapper">
                <div class="aspect-w-16 aspect-h-9">
                    <iframe 
                        src="https://www.youtube.com/embed/<%= video.id %>"
                        class="w-full h-full"
                        frameborder="0" 
                        allowfullscreen>
                    </iframe>
                </div>
            </div>
        </div>
    </section>

    <!-- UNIRME SECTION -->
    <section class="py-12 text-center">
        <div class="container">
            <a href="<%= ctaButton.url %>" class="btn-primary">
                ¡UNIRME AHORA!
            </a>
        </div>
    </section>

    <!-- INFO SECTIONS -->
    <section id="info" class="py-16 bg-gray-50">
        <div class="container space-y-8">
            <div class="info-block">
                <h2 class="text-2xl font-bold mb-4">Análisis técnico profesional</h2>
                <p class="text-gray-600">Aprende las mejores estrategias del mercado</p>
            </div>
            
            <div class="info-block">
                <h2 class="text-2xl font-bold mb-4">Estrategias de trading probadas</h2>
                <p class="text-gray-600">Metodologías que funcionan en el mundo real</p>
            </div>
            
            <div class="info-block">
                <h2 class="text-2xl font-bold mb-4">Gestión de riesgo y capital</h2>
                <p class="text-gray-600">Protege y maximiza tu inversión</p>
            </div>
        </div>
    </section>

    <!-- CONTACTO SECTION -->
    <section id="contacto" class="py-16">
        <div class="container max-w-xl mx-auto text-center">
            <h2 class="text-3xl font-bold mb-8">Contacto</h2>
            <form class="space-y-4">
                <input 
                    type="email" 
                    placeholder="Tu email" 
                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-black focus:border-transparent"
                >
                <button type="submit" class="btn-primary">
                    Enviar
                </button>
            </form>
        </div>
    </section>
</body>
</html> 