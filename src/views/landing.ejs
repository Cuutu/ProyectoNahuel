<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CryptoTrading</title>
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="stylesheet" href="/css/popup.css">
</head>
<body>
    <!-- HEADER -->
    <%- include('./partials/header') %>

    <main>
    <!-- VIDEO SECTION -->
    <section id="video" class="video-section" data-animate="fade-up">
        <div class="container">
            <div class="video-wrapper">
                <iframe 
                    src="https://player.vimeo.com/video/1019511294?h=7d6b5c2f25"
                    width="100%"
                    height="100%"
                    frameborder="0"
                    allow="autoplay; fullscreen; picture-in-picture"
                    allowfullscreen>
                </iframe>
            </div>
        </div>
    </section>

    <!-- UNIRME SECTION -->
    <section class="unirme-section">
        <div class="container">
            <a href="/registro" class="cta-button">¡UNIRME AHORA!</a>
        </div>
    </section>

    <!-- INFO SECTIONS -->
    <section id="info" class="info-section">
        <div class="container">
            <div class="info-block">
                <h2>Análisis técnico profesional</h2>
                <p>Aprende las mejores estrategias del mercado</p>
            </div>
            
            <div class="info-block">
                <h2>Estrategias de trading probadas</h2>
                <p>Metodologías que funcionan en el mundo real</p>
            </div>
            
            <div class="info-block">
                <h2>Gestión de riesgo y capital</h2>
                <p>Protege y maximiza tu inversión</p>
            </div>
        </div>
    </section>

    <!-- CONTACTO SECTION -->
    <section id="contacto" class="contact-section">
        <div class="container">
            <h2>Contacto</h2>
            <form class="contact-form">
                <input type="email" placeholder="Tu email">
                <button type="submit" class="cta-button">Enviar</button>
            </form>
        </div>
    </section>

    </main>


    <!-- Agregar antes del cierre del body -->
    <div id="leadPopup" class="popup-overlay">
        <div class="popup-content">
            <button class="close-popup">&times;</button>
            <div class="popup-header">
                <h3>¡OBTENÉ TU REGALO!</h3>
                <p>Guía PDF: "5 Estrategias Secretas de Trading Cripto"</p>
            </div>
            <form id="leadForm" class="lead-form">
                <input type="email" placeholder="Tu mejor email" required>
                <button type="submit" class="cta-button">DESCARGAR AHORA</button>
            </form>
            <p class="privacy-text">No compartimos tu información con nadie</p>
        </div>
    </div>

    <script src="/js/navbar.js"></script>
    <script src="/js/popup.js"></script>
    <script src="/js/animations.js"></script>

</body>
</html> 