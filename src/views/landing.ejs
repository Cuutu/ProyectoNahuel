<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">CryptoTrading</a>
            <div class="nav-links">
                <a href="#video">Video</a>
                <a href="#caracteristicas">Características</a>
                <a href="#contacto">Contacto</a>
            </div>
        </div>
    </nav>

    <main>
        <section class="hero">
            <div class="container">
                <h1><%= title %></h1>
                <p class="hero-description"><%= description %></p>
                <a href="<%= ctaButton.url %>" class="cta-button">¡COMIENZA AHORA!</a>
            </div>
        </section>

        <section id="video" class="video-section">
            <div class="container">
                <div class="video-wrapper">
                    <iframe 
                        width="100%" 
                        height="515" 
                        src="https://www.youtube.com/embed/<%= video.id %>"
                        title="YouTube video player" 
                        frameborder="0" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                        allowfullscreen>
                    </iframe>
                </div>
            </div>
        </section>

        <section id="caracteristicas" class="features-section">
            <div class="container">
                <h2>¿Qué aprenderás?</h2>
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon">✨</div>
                        <h3>Análisis técnico profesional</h3>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">✨</div>
                        <h3>Estrategias de trading probadas</h3>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">✨</div>
                        <h3>Gestión de riesgo y capital</h3>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 CryptoTrading. Todos los derechos reservados.</p>
        </div>
    </footer>
</body>
</html> 