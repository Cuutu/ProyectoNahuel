<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
</head>
<body>
    <!-- HEADER -->
    <header class="header">
        <div class="nav-container">
            <a href="/" class="logo">CryptoTrading</a>
            <nav class="nav-links">
                <a href="https://www.google.com.ar" target="_blank">Servicios</a>
                <a href="#entrenamientos">Entrenamientos</a>
                <a href="#asesoramientos">Asesoramientos</a>
                <a href="#recursos">Recursos</a>
            </nav>
        </div>
    </header>

    <!-- VIDEO SECTION -->
    <section id="video" class="video-section">
        <div class="container">
            <div class="video-wrapper">
                <iframe 
                    src="https://player.vimeo.com/video/1019511294?speed=0&color=ff9c00&muted=1&autoplay=1&pip=0&loop=1&quality=undefined&app_id=122963&texttrack=undefined"
                    frameborder="0" 
                    allowfullscreen>
                </iframe>
            </div>
        </div>
    </section>

    <!-- UNIRME SECTION -->
    <section class="unirme-section">
        <div class="container">
            <a href="<%= ctaButton.url %>" class="cta-button">¡UNIRME AHORA!</a>
        </div>
    </section>

    <!-- INFO SECTIONS -->
    <section id="info" class="info-section">
        <div class="container">
            <div class="info-block">
                <h2>Análisis técnico profesional</h2>
                <p>Aprende las mejores estrategias del mercado</p>
            </div>
            
            <div class="info-block">
                <h2>Estrategias de trading probadas</h2>
                <p>Metodologías que funcionan en el mundo real</p>
            </div>
            
            <div class="info-block">
                <h2>Gestión de riesgo y capital</h2>
                <p>Protege y maximiza tu inversión</p>
            </div>
        </div>
    </section>

    <!-- CONTACTO SECTION -->
    <section id="contacto" class="contact-section">
        <div class="container">
            <h2>Contacto</h2>
            <form class="contact-form">
                <input type="email" placeholder="Tu email">
                <button type="submit" class="cta-button">Enviar</button>
            </form>
        </div>
    </section>
</body>
</html> 