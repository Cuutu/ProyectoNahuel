<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Análisis Técnico - CryptoTrading</title>
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/training.css">
    <link rel="stylesheet" href="/css/animations.css">
</head>
<body>
    <%- include('../partials/header') %>
    
    <main class="training-detail-container">
        <!-- Hero Section con Título -->
        <section class="course-hero" data-animate="fade-up">
            <div class="container">
                <h1>Análisis Técnico</h1>
                <p class="course-subtitle">Domina el arte del trading con análisis técnico profesional</p>
            </div>
        </section>

        <!-- Video Section -->
        <section class="video-section" data-animate="fade-up">
            <div class="container">
                <div class="video-wrapper">
                    <iframe 
                        src="https://player.vimeo.com/video/1019511294?h=7d6b5c2f25"
                        width="100%"
                        height="100%"
                        frameborder="0"
                        allow="autoplay; fullscreen; picture-in-picture"
                        allowfullscreen>
                    </iframe>
                </div>
            </div>
        </section>

        <!-- Contador de Usuarios con Iconos -->
        <section class="stats-counter" data-animate="fade-up">
            <div class="container">
                <div class="counter-wrapper">
                    <div class="counter-item">
                        <i class="fas fa-users"></i>
                        <span class="counter-number">1,234</span>
                        <span class="counter-label">Estudiantes Activos</span>
                    </div>
                    <div class="counter-item">
                        <i class="fas fa-star"></i>
                        <span class="counter-number">98%</span>
                        <span class="counter-label">Satisfacción</span>
                    </div>
                    <div class="counter-item">
                        <i class="fas fa-chart-line"></i>
                        <span class="counter-number">4.8</span>
                        <span class="counter-label">Valoración</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Características Destacadas -->
        <section class="features-section" data-animate="fade-up">
            <div class="container">
                <h2>¿Por qué elegir este curso?</h2>
                <div class="features-grid">
                    <div class="feature-card">
                        <i class="fas fa-book-open"></i>
                        <h3>Contenido Actualizado</h3>
                        <p>Material didáctico actualizado con las últimas tendencias del mercado</p>
                    </div>
                    <div class="feature-card">
                        <i class="fas fa-hands-helping"></i>
                        <h3>Soporte Personalizado</h3>
                        <p>Acceso directo a mentores expertos para resolver tus dudas</p>
                    </div>
                    <div class="feature-card">
                        <i class="fas fa-laptop-code"></i>
                        <h3>Práctica Real</h3>
                        <p>Ejercicios prácticos en mercados reales</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Roadmap con Diseño Moderno -->
        <section class="roadmap-section" data-animate="fade-up">
            <div class="container">
                <h2>Tu Camino al Éxito</h2>
                <div class="roadmap">
                    <div class="roadmap-item">
                        <div class="roadmap-content">
                            <span class="week">Semana 1-2</span>
                            <h3>Fundamentos del Análisis Técnico</h3>
                            <ul>
                                <li>Introducción al análisis técnico</li>
                                <li>Tipos de gráficos</li>
                                <li>Conceptos básicos de tendencias</li>
                            </ul>
                        </div>
                    </div>
                    <div class="roadmap-item">
                        <div class="roadmap-content">
                            <span class="week">Semana 3-4</span>
                            <h3>Patrones de Velas Japonesas</h3>
                            <ul>
                                <li>Patrones básicos</li>
                                <li>Patrones de reversión</li>
                                <li>Patrones de continuación</li>
                            </ul>
                        </div>
                    </div>
                    <div class="roadmap-item">
                        <div class="roadmap-content">
                            <span class="week">Semana 5-6</span>
                            <h3>Indicadores Técnicos</h3>
                            <ul>
                                <li>Medias móviles</li>
                                <li>RSI, MACD, Estocástico</li>
                                <li>Bandas de Bollinger</li>
                            </ul>
                        </div>
                    </div>
                    <div class="roadmap-item">
                        <div class="roadmap-content">
                            <span class="week">Semana 7-8</span>
                            <h3>Estrategias y Gestión de Riesgo</h3>
                            <ul>
                                <li>Desarrollo de estrategias</li>
                                <li>Gestión de capital</li>
                                <li>Plan de trading</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Sección de Precios Mejorada -->
        <section class="pricing-section" data-animate="fade-up">
            <div class="container">
                <div class="pricing-card">
                    <div class="pricing-header">
                        <h3>Curso Completo</h3>
                        <div class="price">$199.99</div>
                    </div>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check"></i> Acceso de por vida</li>
                        <li><i class="fas fa-check"></i> Certificado de finalización</li>
                        <li><i class="fas fa-check"></i> Recursos descargables</li>
                        <li><i class="fas fa-check"></i> Soporte premium</li>
                    </ul>
                    <button class="cta-button">Inscribirme Ahora</button>
                </div>
            </div>
        </section>
    </main>

    <!-- Sección de Calendario para Profesores -->
    <% if (locals.user && locals.user.role === 'teacher') { %>
        <section class="teacher-schedule-section" data-animate="fade-up">
            <div class="container">
                <h2>Programar Clases</h2>
                <div class="schedule-container">
                    <div class="calendar-wrapper">
                        <input type="text" id="teacher-calendar" placeholder="Selecciona fecha y hora de la clase" class="schedule-input">
                    </div>
                    <div class="schedule-info">
                        <h3>Detalles de la Clase</h3>
                        <p>Duración: 2 horas</p>
                        <div id="selected-class-datetime"></div>
                        <button id="schedule-class" class="cta-button">Programar Clase</button>
                    </div>
                </div>
            </div>
        </section>
    <% } %>

    <!-- Font Awesome para iconos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <script src="/js/animations.js"></script>
    <script src="/js/navbar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://apis.google.com/js/api.js"></script>
    <script src="/js/teacher-schedule.js"></script>
</body>
</html> 