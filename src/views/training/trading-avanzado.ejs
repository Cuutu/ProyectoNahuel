        </section> 

        <!-- Roadmap con Diseño Moderno -->
        <section class="roadmap-section">
            <h2>Roadmap del Curso</h2>
            <div class="container">
                <div class="relative">
                    <!-- Línea horizontal del timeline -->
                    <div class="timeline-line"></div>

                    <!-- Contenido del timeline -->
                    <div class="timeline-content">
                        <!-- Semana 1 - Arriba -->
                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-line-vertical up"></div>
                            <div class="timeline-card up">
                                <div class="card-content">
                                    <div class="card-header">
                                        <p class="week">Semana 1</p>
                                        <h3>Estrategias Avanzadas</h3>
                                    </div>
                                    <ul>
                                        <li><i class="fas fa-check"></i>Estrategias de momentum</li>
                                        <li><i class="fas fa-check"></i>Trading en múltiples temporalidades</li>
                                        <li><i class="fas fa-check"></i>Análisis de volumen avanzado</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- Semana 2 - Abajo -->
                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-line-vertical down"></div>
                            <div class="timeline-card down">
                                <div class="card-content">
                                    <div class="card-header">
                                        <p class="week">Semana 2</p>
                                        <h3>Análisis Técnico Profundo</h3>
                                    </div>
                                    <ul>
                                        <li><i class="fas fa-check"></i>Patrones armónicos</li>
                                        <li><i class="fas fa-check"></i>Ondas de Elliott</li>
                                        <li><i class="fas fa-check"></i>Fibonacci avanzado</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- Semana 3 - Arriba -->
                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-line-vertical up"></div>
                            <div class="timeline-card up">
                                <div class="card-content">
                                    <div class="card-header">
                                        <p class="week">Semana 3</p>
                                        <h3>Trading Algorítmico</h3>
                                    </div>
                                    <ul>
                                        <li><i class="fas fa-check"></i>Introducción a los bots de trading</li>
                                        <li><i class="fas fa-check"></i>Backtesting de estrategias</li>
                                        <li><i class="fas fa-check"></i>Automatización básica</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- Semana 4 - Abajo -->
                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-line-vertical down"></div>
                            <div class="timeline-card down">
                                <div class="card-content">
                                    <div class="card-header">
                                        <p class="week">Semana 4</p>
                                        <h3>Gestión de Portafolio</h3>
                                    </div>
                                    <ul>
                                        <li><i class="fas fa-check"></i>Diversificación avanzada</li>
                                        <li><i class="fas fa-check"></i>Gestión de riesgo profesional</li>
                                        <li><i class="fas fa-check"></i>Optimización de cartera</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script src="/js/navbar.js"></script>
