<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trading Avanzado - CryptoTrading</title>
    
    <!-- Flatpickr CSS y Scripts -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
    
    <!-- Otros estilos -->
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/training.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="preload" href="/css/landing.css" as="style">
    <link rel="stylesheet" href="/css/roadmap.css">
    <link rel="stylesheet" href="/css/calendar.css">
</head>
<body>
    <%- include('../partials/header') %>
    
    <main class="training-detail-container">
        <!-- Hero Section con fondo azul -->
        <section class="hero-section-blue">
            <div class="container">
                <h1>Trading Avanzado</h1>
                <p class="hero-description">Domina estrategias avanzadas de trading y optimiza tus operaciones</p>
            </div>
        </section>

        <!-- Contenido del Curso -->
        <section class="course-content">
            <div class="container">
                <!-- Info del curso -->
                <div class="course-info-center">
                    <p>Duración: 8 semanas</p>
                    <p>Precio: $299.99</p>
                </div>

                <!-- Timeline del Curso -->
                <div class="course-timeline">
                    <div class="timeline-weeks">
                        <div class="week-item">
                            <h3>Semana 1: Estrategias Avanzadas</h3>
                        </div>
                        <div class="week-item">
                            <h3>Semana 2: Análisis Técnico Profundo</h3>
                        </div>
                        <div class="week-item">
                            <h3>Semana 3: Trading Algorítmico</h3>
                        </div>
                        <div class="week-item">
                            <h3>Semana 4: Gestión de Portafolio</h3>
                        </div>
                    </div>

                    <div class="timeline-content">
                        <ul class="content-list">
                            <li>Estrategias de momentum</li>
                            <li>Trading en múltiples temporalidades</li>
                            <li>Análisis de volumen avanzado</li>
                            <li>Patrones armónicos</li>
                            <li>Ondas de Elliott</li>
                            <li>Fibonacci avanzado</li>
                            <li>Introducción a los bots de trading</li>
                            <li>Backtesting de estrategias</li>
                            <li>Automatización básica</li>
                            <li>Diversificación avanzada</li>
                            <li>Gestión de riesgo profesional</li>
                            <li>Optimización de cartera</li>
                        </ul>
                        <div class="timeline-dots">
                            <span class="dot"></span>
                            <span class="dot"></span>
                            <span class="dot"></span>
                            <span class="dot"></span>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script src="/js/navbar.js"></script>
</body>
</html> 