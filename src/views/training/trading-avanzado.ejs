<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trading Avanzado - CryptoTrading</title>
    
    <!-- Flatpickr CSS y Scripts -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
    
    <!-- Otros estilos -->
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/training.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="preload" href="/css/landing.css" as="style">
    <link rel="stylesheet" href="/css/roadmap.css">
    <link rel="stylesheet" href="/css/calendar.css">
</head>
<body>
    <%- include('../partials/header') %>
    
    <main class="training-detail-container">
        <!-- Hero Section con Título -->
        <section class="hero-section">
            <div class="container">
                <h1>Trading Avanzado</h1>
                <p class="hero-description">Domina estrategias avanzadas de trading y optimiza tus operaciones</p>
            </div>
        </section>

        <!-- Contenido del Curso -->
        <section class="course-content">
            <div class="container">
                <div class="course-info">
                    <div class="info-item">
                        <i class="fas fa-clock"></i>
                        <span>Duración: 8 semanas</span>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-dollar-sign"></i>
                        <span>Precio: $299.99</span>
                    </div>
                </div>

                <!-- Timeline del Curso -->
                <div class="timeline-container">
                    <!-- Semana 1 -->
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h3>Semana 1: Estrategias Avanzadas</h3>
                            <ul>
                                <li><i class="fas fa-check"></i>Estrategias de momentum</li>
                                <li><i class="fas fa-check"></i>Trading en múltiples temporalidades</li>
                                <li><i class="fas fa-check"></i>Análisis de volumen avanzado</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Semana 2 -->
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h3>Semana 2: Análisis Técnico Profundo</h3>
                            <ul>
                                <li><i class="fas fa-check"></i>Patrones armónicos</li>
                                <li><i class="fas fa-check"></i>Ondas de Elliott</li>
                                <li><i class="fas fa-check"></i>Fibonacci avanzado</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Semana 3 -->
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h3>Semana 3: Trading Algorítmico</h3>
                            <ul>
                                <li><i class="fas fa-check"></i>Introducción a los bots de trading</li>
                                <li><i class="fas fa-check"></i>Backtesting de estrategias</li>
                                <li><i class="fas fa-check"></i>Automatización básica</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Semana 4 -->
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h3>Semana 4: Gestión de Portafolio</h3>
                            <ul>
                                <li><i class="fas fa-check"></i>Diversificación avanzada</li>
                                <li><i class="fas fa-check"></i>Gestión de riesgo profesional</li>
                                <li><i class="fas fa-check"></i>Optimización de cartera</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script src="/js/navbar.js"></script>
</body>
</html> 