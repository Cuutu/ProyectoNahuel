<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Nahuel Lozano</title>
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
    <%- include('./partials/header') %>
    
    <div class="error-container">
        <div class="error-content">
            <h1>Ha ocurrido un error</h1>
            <p class="error-message"><%= message %></p>
            
            <% if (process.env.NODE_ENV === 'development' && error.stack) { %>
                <div class="error-details">
                    <pre><%= error.stack %></pre>
                </div>
            <% } %>
            
            <div class="error-actions">
                <a href="<%= returnTo %>" class="btn btn-secondary">Volver</a>
                <a href="/" class="btn btn-primary">Ir al inicio</a>
            </div>
        </div>
    </div>

    <style>
        .error-container {
            max-width: 800px;
            margin: 50px auto;
            padding: 20px;
        }
        
        .error-content {
            background: #fff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            text-align: center;
        }
        
        .error-message {
            color: #dc3545;
            margin: 20px 0;
        }
        
        .error-details {
            text-align: left;
            background: #f8f9fa;
            padding: 15px;
            border-radius: 4px;
            margin: 20px 0;
            overflow-x: auto;
        }
        
        .error-actions {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-top: 20px;
        }
        
        .btn {
            padding: 10px 20px;
            border-radius: 4px;
            text-decoration: none;
            font-weight: 500;
        }
        
        .btn-primary {
            background: #00ff88;
            color: #000;
        }
        
        .btn-secondary {
            background: #6c757d;
            color: #fff;
        }
    </style>
</body>
</html> 